#!/usr/bin/env -S php -dphar.readonly=0
<?php
define('BUILD_DIR', './build');

$opts = getopt('', ['template:', 'name:', 'package:', 'phar', 'compat-src-main']);
if (!$opts) {
  die('Usage: bin/build --name="Package name" --package=package [--phar] [--compat-src-main]' . PHP_EOL);
}

if (!isset($opts['name'])) {
  die('Error: you should pass --name with name of project to build' . PHP_EOL);
}

if (!isset($opts['package'])) {
  die('Error: you should pass --package with binary name to build' . PHP_EOL);
}

if (isset($opts['compat-src-main']) && !isset($opts['phar'])) {
  die('Error: --compat-src-main requires --phar' . PHP_EOL);
}

$TPL_PATH = realpath(__DIR__ . '/../templates');
$TEMPLATES = glob("$TPL_PATH/*") ?: [];
$template = $opts['template'] ?? null;
if ($template && !in_array($template, array_map('basename', $TEMPLATES))) {
  die('Error: you passed unexisting template to use. Check templates dir for allowed templates' . PHP_EOL);
}

$binFile = BUILD_DIR . '/' . $opts['package'];
$srcDir = BUILD_DIR . '/share/modules/' . $opts['package'];
$entrypoint = 'src/main.php';

if (is_dir(BUILD_DIR)) {
  exec('rm -fr ' . BUILD_DIR);
}
mkdir(BUILD_DIR, 0755);
mkdir($srcDir, 0755, true);

// Now add all deps required by composer
// We create new fake vendor and install only no dev packages
// just because there is no way to dump autoload config of non dev-only
shell_exec("cp -r src '$srcDir/src'");
copy('APP_VERSION', $srcDir . '/APP_VERSION');
copy('composer.json', $srcDir . '/composer.json');
copy('composer.lock', $srcDir . '/composer.lock');
shell_exec('cd ' . $srcDir . ' && composer install --prefer-dist --no-dev --optimize-autoloader');
$buildVendorDir = $srcDir . '/vendor';
// Remove tests from vendor dir
shell_exec('find ' . $buildVendorDir . ' -type d -name tests | xargs rm -fr');

$templates = $template ? [$TPL_PATH . '/' . $template] : $TEMPLATES;
echo 'Build for templates: ' . implode(',', array_map(basename(...), $templates)) . PHP_EOL;

$wrappers = [];
foreach ($templates as $template) {
  $content = file_get_contents($template);
  $content = strtr($content, [
    '__NAME__' => $opts['name'],
    '__PACKAGE__' => $opts['package'],
  ]);

  $extension = basename($template);
  $curFile = $binFile . '.' . $extension;
  file_put_contents($curFile, $content);
  chmod($curFile, 0777);
  $wrappers[] = $curFile;
  echo '- ' . $curFile . PHP_EOL;

  // Make identical copy for shell script without extension
  // to make it easier for all things we already have in CI
  if ($extension === 'sh') {
    copy($curFile, $binFile);
    chmod($binFile, 0777);
    $wrappers[] = $binFile;
    echo '- ' . $binFile . PHP_EOL;
  }
}

if (isset($opts['phar'])) {
  $pharName = $opts['package'] . '.phar';
  $pharPath = $srcDir . '/' . $pharName;
  $tmpPharPath = BUILD_DIR . '/' . $pharName;
  $entrypoint = str_replace('\\', '/', $entrypoint);

  if (!is_file($srcDir . '/' . $entrypoint)) {
    die("Error: missing PHAR entrypoint $srcDir/$entrypoint" . PHP_EOL);
  }

  @unlink($tmpPharPath);
  @unlink($pharPath);
  $phar = new Phar($tmpPharPath);
  $phar->startBuffering();
  $phar->buildFromDirectory($srcDir);
  $phar->setStub("#!/usr/bin/env php\n<?php\nPhar::mapPhar('$pharName');\nrequire 'phar://$pharName/$entrypoint';\n__HALT_COMPILER();\n");
  $phar->stopBuffering();
  unset($phar);

  rename($tmpPharPath, $pharPath) || die("Error: failed to move PHAR to $pharPath" . PHP_EOL);
  foreach (new DirectoryIterator($srcDir) as $entry) {
    if (!$entry->isDot() && $entry->getFilename() !== $pharName) {
      shell_exec('rm -rf ' . escapeshellarg($entry->getPathname()));
    }
  }

  if (isset($opts['compat-src-main'])) {
    mkdir($srcDir . '/src', 0755, true);
    file_put_contents($srcDir . '/src/main.php', <<<PHP
<?php declare(strict_types=1);

\$phar = dirname(__DIR__) . DIRECTORY_SEPARATOR . '$pharName';
if (!is_file(\$phar)) {
    fwrite(STDERR, "PHAR payload not found: {\$phar}" . PHP_EOL);
    exit(1);
}
require 'phar://' . \$phar . '/$entrypoint';
PHP);
  }

  foreach ($wrappers as $wrapper) {
    $content = file_get_contents($wrapper);
    $updated = str_replace(
      [
        'elif [ -d "$SCRIPT_DIR/../src/main.php" ]; then' . "\n" . '  src_dir="$SCRIPT_DIR/.."',
        '"$src_dir/src/main.php"',
        '"$srcDir\\src\\main.php"',
      ],
      [
        'elif [ -f "$SCRIPT_DIR/../' . $pharName . '" ]; then' . "\n" . '  src_dir="$SCRIPT_DIR/.."',
        '"$src_dir/' . $pharName . '"',
        '"$srcDir\\' . $pharName . '"',
      ],
      $content
    );
    if ($updated === $content || file_put_contents($wrapper, $updated) === false) {
      die("Error: failed to rewrite wrapper $wrapper to launch $pharName" . PHP_EOL);
    }
    echo "- $wrapper (PHAR)" . PHP_EOL;
  }
}
